rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnUserDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        (
          request.auth.token.email == 'superadmin@pulalabs.com' ||
          request.auth.token.email == 'superadmin@aivyapari.com'
        );
    }

    function isWorkspaceMember(userId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'team_member' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceOwnerId == userId;
    }

    function managesTeamAccount(userId) {
      return isSignedIn() && (
        (
          request.resource != null &&
          request.resource.data.accountType == 'team_member' &&
          request.resource.data.workspaceOwnerId == request.auth.uid
        ) ||
        (
          resource != null &&
          resource.data.accountType == 'team_member' &&
          resource.data.workspaceOwnerId == request.auth.uid
        )
      );
    }

    function hasWorkspacePermission(userId, permission) {
      return isWorkspaceMember(userId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny([permission]);
    }

    function createsOwnerProfile(userId) {
      return isOwnUserDocument(userId) &&
        request.resource.data.accountType == 'owner' &&
        request.resource.data.workspaceOwnerId == userId;
    }

    function preservesOwnIdentity() {
      return request.resource.data.get('accountType', 'owner') == resource.data.get('accountType', 'owner') &&
        request.resource.data.get('workspaceOwnerId', '') == resource.data.get('workspaceOwnerId', '') &&
        request.resource.data.get('linkedTeamMemberId', '') == resource.data.get('linkedTeamMemberId', '');
    }

    match /users/{userId} {
      allow read: if isSuperAdmin() || isOwner(userId) || isWorkspaceMember(userId) || managesTeamAccount(userId);
      allow create: if isSuperAdmin() || createsOwnerProfile(userId) || managesTeamAccount(userId);
      allow update: if isSuperAdmin() || (isOwnUserDocument(userId) && preservesOwnIdentity()) || managesTeamAccount(userId);
      allow delete: if isSuperAdmin();

      match /{document=**} {
        allow read: if isSuperAdmin() || isOwner(userId) || isWorkspaceMember(userId);
        allow create: if isSuperAdmin() || isOwner(userId) || hasWorkspacePermission(userId, 'create');
        allow update: if isSuperAdmin() || isOwner(userId) || hasWorkspacePermission(userId, 'edit');
        allow delete: if isSuperAdmin() || isOwner(userId) || hasWorkspacePermission(userId, 'delete');
      }
    }

    match /supportThreads/{ticketId} {
      allow read: if isSuperAdmin() || (
        resource.data.ownerUserId != null &&
        (isOwner(resource.data.ownerUserId) || isWorkspaceMember(resource.data.ownerUserId))
      );

      allow create: if isSuperAdmin() || (
        request.resource.data.ownerUserId != null &&
        (isOwner(request.resource.data.ownerUserId) || hasWorkspacePermission(request.resource.data.ownerUserId, 'create'))
      );

      allow update: if isSuperAdmin() || (
        resource.data.ownerUserId != null &&
        (isOwner(resource.data.ownerUserId) || hasWorkspacePermission(resource.data.ownerUserId, 'edit'))
      );

      allow delete: if isSuperAdmin();
    }

    match /platformSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /platformCoupons/{couponId} {
      allow read, write: if isSuperAdmin();
    }

    match /cashRegisterCategorySuggestions/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }
  }
}
